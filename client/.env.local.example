# API URL - relative path for Express integration
# All /api/* requests are proxied by Express server
NEXT_PUBLIC_API_URL=/api

# Database URL for Server Actions (Prisma)
# In production, this is inherited from Railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Cloudinary (must match server settings)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Admin Session (optional - for middleware JWT verification)
# If not set, defaults to JWT_SECRET from server
ADMIN_SESSION_SECRET=your-admin-session-secret-change-in-production
