{
  "name": "shop-client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:custom": "node server.js",
    "lint": "next lint --fix",
    "clean": "node -e \"const fs=require('fs');const path=require('path');const p=path.join(process.cwd(),'.next');if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});console.log('✅ .next видалено')\"",
    "clean:all": "node -e \"const fs=require('fs');const path=require('path');const p=path.join(process.cwd(),'.next');const n=path.join(process.cwd(),'node_modules');if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});if(fs.existsSync(n))fs.rmSync(n,{recursive:true,force:true});console.log('✅ .next і node_modules видалено')\"",
    "rebuild": "npm run clean:all && npm install && npm run build"
  },
  "dependencies": {
    "@react-leaflet/core": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.7",
    "cloudinary": "^2.9.0",
    "express": "^4.18.2",
    "jose": "^6.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.330.0",
    "next": "^14.2.0",
    "postcss": "^8.4.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.50.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.0",
    "styled-jsx": "^5.1.6",
    "tailwindcss": "^3.4.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
