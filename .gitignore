# ==================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.test
.env.production
*.env
!.env.example
!.env.build

# ==================================
# Database
# ==================================
# Prisma
prisma/*.db
prisma/*.db-journal
*.db
*.sqlite
*.sqlite3

# Migrations (optional - uncomment if you don't want to commit migrations)
# prisma/migrations/

# ==================================
# Logs
# ==================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

