# ==================================
# GoodsXP - .gitignore
# ==================================

# ==================================
# Dependencies
# ==================================
node_modules/
.pnp
.pnp.js
.npm
.yarn
yarn-error.log

# Keep package-lock.json for builds
# package-lock.json
# yarn.lock

# ==================================
# Build outputs
# ==================================
# Next.js
.next/
out/
build/
dist/
*.tsbuildinfo

# Server
server/dist/
server/build/

# Client
client/.next/
client/out/
client/build/
client/dist/

# ==================================
# Environment variables
# ==================================
# Ignore all .env files EXCEPT templates
*.env
!.env.example
.env.railway
server/.env.railway

# ==================================
# Database
# ==================================
# Prisma - ignore only database files, NOT schema
prisma/*.db
prisma/*.db-journal
*.db
*.sqlite
*.sqlite3

# Migrations ARE committed
# prisma/migrations/

# ==================================
# Logs
# ==================================
# Log files (not Next.js pages)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Root logs directory only
/logs/

# ==================================
# IDE and editors
# ==================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
Desktop.ini

# ==================================
# Testing
# ==================================
coverage/
.nyc_output/
*.lcov
.jest/

# ==================================
# Misc
# ==================================
.cache/
temp/
tmp/
.temp/
.tmp/

# ==================================
# Uploads (server)
# ==================================
server/uploads/
uploads/
*.upload

# Client uploads - keep directory but ignore files
client/public/uploads/*
!client/public/uploads/.gitkeep

# ==================================
# TypeScript
# ==================================
*.tsbuildinfo
next-env.d.ts

# ==================================
# Vercel
# ==================================
.vercel

# ==================================
# Docker
# ==================================
docker-compose.override.yml
*.pid

# ==================================
# OS generated files
# ==================================
ehthumbs.db
Icon?
._*
.DocumentRevisions-V100
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDouble
.LSOverride

# ==================================
# Sensitive files
# ==================================
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
credentials/

# ==================================
# Documentation (optional)
# ==================================
# README.md
# CHANGELOG.md
# CONTRIBUTING.md
nul  
