# ==================================
# GoodsXP - Environment Variables Template
# ==================================
# Скопіюйте цей файл в .env і заповніть значеннями:
# cp .env.example .env

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/goodsxp

# Server
PORT=5000

# JWT — згенеруйте: openssl rand -hex 64
JWT_SECRET=your-random-64-character-secret-key-here
JWT_EXPIRES_IN=7d

# Frontend
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://goodsxp.store

# Admin
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=StrongPassword123!@#

# Hidden Admin Panel Path (змініть на випадковий шлях)
ADMIN_PANEL_PATH=/admin-x8k2p9-panel

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Nova Poshta
NOVA_POSHTA_API_KEY=your-api-key

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
