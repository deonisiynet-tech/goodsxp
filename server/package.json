{
  "name": "shop-server",
  "version": "1.0.0",
  "description": "E-commerce backend with Next.js frontend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs');const path=require('path');const src=path.join(__dirname,'prisma','migrations');const dst=path.join(__dirname,'dist','prisma','migrations');fs.mkdirSync(dst,{recursive:true});fs.cpSync(src,dst,{recursive:true,force:true});\"",
    "build:client": "cd ../client && npm install && npm run build",
    "build:all": "npm run build:client && npm run build",
    "start": "node dist/server.js",
    "postinstall": "prisma generate --schema ./prisma/schema.prisma",
    "migrate": "tsx src/prisma/migrate.ts",
    "migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev",
    "check-db": "tsx src/prisma/check-db.ts",
    "prisma:generate": "dotenv -e ../.env -- prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:studio": "dotenv -e ../.env -- prisma studio --schema ./prisma/schema.prisma",
    "seed": "tsx src/prisma/seed.ts"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/next": "^9.0.0",
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "dotenv-cli": "^11.0.0",
    "next": "^14.1.0",
    "prisma": "^6.19.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
