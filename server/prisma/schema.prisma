generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(uuid())
  email                String      @unique
  password             String
  role                 Role        @default(USER)
  twoFASecret          String?
  twoFAEnabled         Boolean     @default(false)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?   @db.Timestamptz(6)
  createdAt            DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @db.Timestamptz(6)
  loginLogs            LoginLog[]
  logs                 AdminLog[]
  orders               Order[]
  systemLogs           SystemLog[]
  sessions             AdminSession[]

  @@index([email])
  @@index([role])
}

model AdminSession {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  location     String?
  lastActive   DateTime @default(now()) @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  expiresAt    DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([lastActive])
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id            String      @id @default(uuid())
  title         String
  description   String
  price         Decimal     @db.Decimal(10, 2)
  margin        Float       @default(0)
  categoryId    String?
  rating        Decimal?    @db.Decimal(3, 2)
  originalPrice Decimal?    @db.Decimal(10, 2)
  discountPrice Decimal?    @db.Decimal(10, 2)
  isFeatured    Boolean     @default(false)
  isPopular     Boolean     @default(false)
  imageUrl      String?
  images        String[]
  stock         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  slug          String      @unique
  orderItems    OrderItem[]
  category      Category?   @relation(fields: [categoryId], references: [id])
  reviews       Review[]
  specifications ProductSpecification[]
  options       ProductOption[]
  variants      ProductVariant[]

  @@index([isActive])
  @@index([createdAt])
  @@index([title])
  @@index([isFeatured])
  @@index([isPopular])
  @@index([categoryId])
  @@index([rating])
  @@index([price])
  @@index([isActive, isFeatured])
  @@index([isActive, isPopular])
  @@index([isActive, categoryId])
  @@index([isActive, createdAt])
  slugRedirects ProductSlugRedirect[]
  productImages ProductImage[]
}

/**
 * Фотографії товару з прив'язкою до варіантів
 * variantValue = null → фото для всіх варіантів
 * variantValue = "black" → фото тільки для варіанту "black"
 */
model ProductImage {
  id           String   @id @default(uuid())
  productId    String
  imageUrl     String
  variantValue String?  // Значення варіанту (наприклад "black", "white") або null для всіх
  position     Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, variantValue])
}

model ProductSpecification {
  id        String  @id @default(uuid())
  productId String
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/**
 * Редіректи для старих slug товарів
 * Коли адмін перейменовує товар — старий slug редіректить на новий
 */
model ProductSlugRedirect {
  id        String   @id @default(uuid())
  oldSlug   String   @unique // Старий slug (наприклад "stara-nazva")
  newSlug   String   // Новий slug (наприклад "nova-nazva-abc123")
  productId String   // ID товару для швидкого пошуку
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([oldSlug])
  @@index([productId])
}

/**
 * Характеристики товару (Колір, Довжина, Памʼять тощо)
 */
model ProductOption {
  id        String   @id @default(uuid())
  productId String
  name      String                 // "Колір", "Довжина", "Памʼять"
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@index([productId])
}

/**
 * Значення характеристики (чорний, білий, 1m, 2m тощо)
 */
model ProductOptionValue {
  id        String   @id @default(uuid())
  optionId  String
  value     String                 // "чорний", "білий", "1m"
  option    ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
}

/**
 * Варіант товару — конкретна комбінація характеристик
 * options: [{ optionId, optionValueId, name, value }, ...]
 */
model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  image       String?  // Фото конкретного варіанту
  options     Json     // Масив [{ optionId, optionValueId, name, value }]
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  name      String
  rating    Int
  comment   String?
  pros      String?  // Переваги (текст, розділений комами або новими рядками)
  cons      String?  // Недоліки (текст, розділений комами або новими рядками)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  userId    String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  images    ReviewImage[]

  @@index([productId])
  @@index([createdAt])
  @@index([rating])
  @@index([userId])
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String
  imageUrl  String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     Int           @unique @default(autoincrement())
  userId          String?
  name            String
  phone           String
  email           String?
  address         String?
  city            String?
  warehouse       String?
  warehouseAddress String?
  totalPrice      Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(NEW)
  paymentMethod   PaymentMethod @default(COD)
  comment         String?
  promoCodeId     String?
  promoCodeValue  String?
  discount        Decimal?      @db.Decimal(10, 2)
  deletedAt       DateTime?     @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)
  user            User?         @relation(fields: [userId], references: [id])
  promoCode       PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@index([userId])
  @@index([deletedAt])
  @@index([promoCodeId])
}

model OrderItem {
  id             String          @id @default(uuid())
  orderId        String
  productId      String
  variantId      String?
  variantOptions Json?
  quantity       Int
  price          Decimal         @db.Decimal(10, 2)
  margin         Float           @default(0)
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([margin])
}

model AdminLog {
  id        String     @id @default(uuid())
  adminId   String
  action    ActionType
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  admin     User       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@index([entity])
}

model SystemLog {
  id        String    @id @default(uuid())
  timestamp DateTime  @default(now()) @db.Timestamptz(6)
  level     LogLevel  @default(INFO)
  message   String
  userId    String?
  ipAddress String?
  source    LogSource @default(SYSTEM)
  metadata  String?
  user      User?     @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([timestamp])
  @@index([source])
  @@index([userId])
}

model SiteSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  type        String   @default("text")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([key])
}

/**
 * Відвідувач сайту (унікальний ID в cookie/localStorage)
 */
model Visitor {
  id              String      @id @default(uuid())
  visitorId       String      @unique // UUID з cookie/localStorage
  fingerprint     String?     // Відбиток браузера (base64 hash)
  firstSeenAt     DateTime    @default(now()) @db.Timestamptz(6)
  lastSeenAt      DateTime    @updatedAt @db.Timestamptz(6)
  userAgent       String?
  ipAddress       String?
  isOnline        Boolean     @default(false)
  createdAt       DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @db.Timestamptz(6)

  @@index([visitorId])
  @@index([fingerprint])
  @@index([isOnline])
  @@index([lastSeenAt])
}

/**
 * Історія відвідувань сайту
 */
model SiteVisit {
  id          String   @id @default(uuid())
  visitorId   String   // Зберігаємо visitorId без foreign key для продуктивності
  page        String?  // URL сторінки
  referrer    String?  // Звідки прийшов
  sessionStart DateTime @default(now()) @db.Timestamptz(6)
  sessionEnd  DateTime? @db.Timestamptz(6)
  duration    Int?     // Тривалість в секундах
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([visitorId])
  @@index([sessionStart])
  @@index([createdAt])
}

/**
 * Логи входов в админ-панель
 */
model LoginLog {
  id          String      @id @default(uuid())
  userId      String?
  email       String      // Email, который пытались использовать
  success     Boolean     // Успешный вход или нет
  ipAddress   String?
  userAgent   String?
  failureReason String?   // Причина неудачи (WRONG_PASSWORD, 2FA_REQUIRED, IP_BLOCKED, etc.)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([success])
  @@index([createdAt])
  @@index([ipAddress])
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  CARD
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  SETTINGS_UPDATE
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum LogSource {
  ADMIN_PANEL
  API
  SYSTEM
}

enum PromoCodeType {
  PERCENTAGE
  FIXED
}

enum ValidityType {
  DAYS
  HOURS
  DATE_RANGE
}

model PromoCode {
  id            String        @id @default(uuid())
  code          String        @unique
  type          PromoCodeType
  value         Decimal       @db.Decimal(10, 2)
  validityType  ValidityType
  duration      Int?
  startDate     DateTime?     @db.Timestamptz(6)
  endDate       DateTime?     @db.Timestamptz(6)
  maxUsageCount Int?
  currentUsage  Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(6)
  orders        Order[]

  @@index([code])
  @@index([isActive])
  @@index([endDate])
}
