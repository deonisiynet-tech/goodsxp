generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(uuid())
  email                String      @unique
  password             String
  role                 Role        @default(USER)
  twoFASecret          String?
  twoFAEnabled         Boolean     @default(false)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?   @db.Timestamptz(6)
  createdAt            DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @db.Timestamptz(6)
  loginLogs            LoginLog[]
  logs                 AdminLog[]
  orders               Order[]
  systemLogs           SystemLog[]

  @@index([email])
  @@index([role])
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id            String      @id @default(uuid())
  title         String
  description   String
  price         Decimal     @db.Decimal(10, 2)
  margin        Float       @default(0)
  categoryId    String?
  rating        Decimal?    @db.Decimal(3, 2)
  originalPrice Decimal?    @db.Decimal(10, 2)
  discountPrice Decimal?    @db.Decimal(10, 2)
  isFeatured    Boolean     @default(false)
  isPopular     Boolean     @default(false)
  imageUrl      String?
  images        String[]
  stock         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  slug          String      @unique
  orderItems    OrderItem[]
  category      Category?   @relation(fields: [categoryId], references: [id])
  reviews       Review[]

  @@index([isActive])
  @@index([createdAt])
  @@index([title])
  @@index([isFeatured])
  @@index([isPopular])
  @@index([categoryId])
  @@index([rating])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  name      String
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  userId    String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@index([rating])
  @@index([userId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     Int           @unique @default(autoincrement())
  userId          String?
  name            String
  phone           String
  email           String?
  address         String?
  city            String?
  warehouse       String?
  warehouseAddress String?
  totalPrice      Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(NEW)
  paymentMethod   PaymentMethod @default(COD)
  comment         String?
  deletedAt       DateTime?     @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)
  user            User?         @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@index([userId])
  @@index([deletedAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  margin    Float   @default(0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model AdminLog {
  id        String     @id @default(uuid())
  adminId   String
  action    ActionType
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  admin     User       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@index([entity])
}

model SystemLog {
  id        String    @id @default(uuid())
  timestamp DateTime  @default(now()) @db.Timestamptz(6)
  level     LogLevel  @default(INFO)
  message   String
  userId    String?
  ipAddress String?
  source    LogSource @default(SYSTEM)
  metadata  String?
  user      User?     @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([timestamp])
  @@index([source])
  @@index([userId])
}

model SiteSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  type        String   @default("text")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([key])
}

/**
 * Відвідувач сайту (унікальний ID в cookie/localStorage)
 */
model Visitor {
  id              String      @id @default(uuid())
  visitorId       String      @unique // UUID з cookie/localStorage
  fingerprint     String?     // Відбиток браузера
  firstSeenAt     DateTime    @default(now()) @db.Timestamptz(6)
  lastSeenAt      DateTime    @updatedAt @db.Timestamptz(6)
  userAgent       String?
  ipAddress       String?
  isOnline        Boolean     @default(false)
  createdAt       DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @db.Timestamptz(6)

  @@index([visitorId])
  @@index([isOnline])
  @@index([lastSeenAt])
}

/**
 * Історія відвідувань сайту
 */
model SiteVisit {
  id          String   @id @default(uuid())
  visitorId   String   // Зберігаємо visitorId без foreign key для продуктивності
  page        String?  // URL сторінки
  referrer    String?  // Звідки прийшов
  sessionStart DateTime @default(now()) @db.Timestamptz(6)
  sessionEnd  DateTime? @db.Timestamptz(6)
  duration    Int?     // Тривалість в секундах
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([visitorId])
  @@index([sessionStart])
  @@index([createdAt])
}

/**
 * Логи входов в админ-панель
 */
model LoginLog {
  id          String      @id @default(uuid())
  userId      String?
  email       String      // Email, который пытались использовать
  success     Boolean     // Успешный вход или нет
  ipAddress   String?
  userAgent   String?
  failureReason String?   // Причина неудачи (WRONG_PASSWORD, 2FA_REQUIRED, IP_BLOCKED, etc.)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([success])
  @@index([createdAt])
  @@index([ipAddress])
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  CARD
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  SETTINGS_UPDATE
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum LogSource {
  ADMIN_PANEL
  API
  SYSTEM
}
